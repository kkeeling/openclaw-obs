{
  "name": "openclaw-obs",
  "version": "0.1.0",
  "description": "Local-first observability for OpenClaw AI agents — traces, cost analytics, and conversation replay in a single dashboard",
  "type": "module",
  "main": "dist/plugin/index.js",
  "bin": {
    "openclaw-obs": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "openclaw",
    "observability",
    "tracing",
    "llm",
    "ai-agents",
    "cost-tracking",
    "sqlite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkeeling/openclaw-obs.git"
  },
  "bugs": {
    "url": "https://github.com/kkeeling/openclaw-obs/issues"
  },
  "homepage": "https://github.com/kkeeling/openclaw-obs#readme",
  "author": "Keenan Keeling",
  "openclaw": {
    "extensions": [
      "./dist/plugin/index.js"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
